{
  "name": "@emdash/wire",
  "version": "1.0.0",
  "description": "Transport-agnostic live model and mutation primitives for Emdash",
  "license": "Apache-2.0",
  "author": {
    "name": "Emdash Contributors",
    "email": "support@emdash.sh"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./live": {
      "types": "./dist/live.d.mts",
      "default": "./dist/live.mjs"
    },
    "./api": {
      "types": "./dist/api.d.mts",
      "default": "./dist/api.mjs"
    },
    "./observability": {
      "types": "./dist/observability.d.mts",
      "default": "./dist/observability.mjs"
    },
    "./testing": {
      "types": "./dist/testing.d.mts",
      "default": "./dist/testing.mjs"
    },
    "./util": {
      "types": "./dist/util.d.mts",
      "default": "./dist/util.mjs"
    },
    "./util/mobx": {
      "types": "./dist/mobx.d.mts",
      "default": "./dist/mobx.mjs"
    },
    "./util/process-runtime": {
      "types": "./dist/process-runtime.d.mts",
      "default": "./dist/process-runtime.mjs"
    },
    "./worker": {
      "types": "./dist/worker.d.mts",
      "default": "./dist/worker.mjs"
    },
    "./process": {
      "types": "./dist/process.d.mts",
      "default": "./dist/process.mjs"
    },
    "./process/node": {
      "types": "./dist/process-node.d.mts",
      "default": "./dist/process-node.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest run",
    "example:live-state": "tsx examples/live-state/client.ts",
    "example:batched-state": "tsx examples/batched-state/client.ts",
    "example:live-log": "tsx examples/live-log/client.ts",
    "example:event-stream": "tsx examples/event-stream/client.ts",
    "example:live-job": "tsx examples/live-job/client.ts",
    "example:scope": "tsx examples/scope/client.ts",
    "example:managed-source": "tsx examples/managed-source/client.ts",
    "example:cancellation": "tsx examples/cancellation/client.ts",
    "example:contract": "tsx examples/contract/client.ts",
    "example:api-definition": "tsx examples/api-definition/inspect.ts",
    "example:controller": "tsx examples/controller/controller.ts",
    "example:api-client": "tsx examples/api-client/client.ts",
    "example:group": "tsx examples/group/client.ts",
    "example:dedupe": "tsx examples/dedupe/server.ts",
    "example:job-contract": "tsx examples/job-contract/client.ts",
    "example:mutation-idempotency": "tsx examples/mutation-idempotency/client.ts",
    "example:multi-window": "tsx examples/multi-window/client.ts",
    "example:logging": "tsx examples/logging/client.ts",
    "example:replica": "tsx examples/replica/client.ts",
    "example:process": "tsx examples/process/client.ts",
    "example:optimistic-live-model": "tsx examples/optimistic-live-model/client.ts",
    "lint": "sh -c 'root=$(cd ../.. && pwd); cd \"$root/apps/emdash-desktop\" && pnpm exec oxlint --config .oxlintrc.json \"$root/packages/wire\"'",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@emdash/shared": "workspace:*",
    "immer": "^10.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.42",
    "@typescript/native-preview": "7.0.0-dev.20260609.1",
    "mobx": "^6.16.1",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.4",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "mobx": "^6.16.1"
  }
}
