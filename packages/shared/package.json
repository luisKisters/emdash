{
  "name": "@emdash/shared",
  "version": "1.0.0",
  "description": "Shared primitives for Emdash",
  "license": "Apache-2.0",
  "author": {
    "name": "Emdash Contributors",
    "email": "support@emdash.sh"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./result": {
      "types": "./dist/result.d.mts",
      "default": "./dist/result.mjs"
    },
    "./config": {
      "types": "./dist/config.d.mts",
      "default": "./dist/config.mjs"
    },
    "./logger": {
      "types": "./dist/logger.d.mts",
      "default": "./dist/logger.mjs"
    },
    "./logger/context": {
      "types": "./dist/logger-context.d.mts",
      "default": "./dist/logger-context.mjs"
    },
    "./logger/context-node": {
      "types": "./dist/logger-context-node.d.mts",
      "default": "./dist/logger-context-node.mjs"
    },
    "./logger/pino": {
      "types": "./dist/logger-pino.d.mts",
      "default": "./dist/logger-pino.mjs"
    },
    "./logger/node": {
      "types": "./dist/logger-node.d.mts",
      "default": "./dist/logger-node.mjs"
    },
    "./logger/transport": {
      "types": "./dist/logger-transport.d.mts",
      "default": "./dist/logger-transport.mjs"
    },
    "./markdown": {
      "types": "./dist/markdown.d.mts",
      "default": "./dist/markdown.mjs"
    },
    "./plugins": {
      "types": "./dist/plugins.d.mts",
      "default": "./dist/plugins.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest run",
    "lint": "sh -c 'root=$(cd ../.. && pwd); cd \"$root/apps/emdash-desktop\" && pnpm exec oxlint --config .oxlintrc.json \"$root/packages/shared\"'",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "fast-redact": "^3.5.0",
    "pino": "^9.14.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.42",
    "@typescript/native-preview": "7.0.0-dev.20260609.1",
    "tsdown": "^0.22.2",
    "vitest": "^4.1.0"
  }
}
