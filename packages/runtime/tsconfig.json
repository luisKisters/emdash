{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "paths": {
      "@emdash/core/acp": ["../core/src/acp/index.ts"],
      "@emdash/core/workspace-server": ["../core/src/workspace-server/index.ts"],
      "@emdash/core/agents/agent-env": ["../core/src/agents/agent-env.ts"],
      "@emdash/core/agents/spawn-context": ["../core/src/agents/spawn-context.ts"],
      "@emdash/core/agents/plugins/helpers": ["../core/src/agents/plugins/helpers/index.ts"],
      "@emdash/core/agents/plugins": ["../core/src/agents/plugins/index.ts"],
      "@emdash/core/deps/runtime": ["../core/src/host-dependencies/runtime/index.ts"],
      "@emdash/core/exec": ["../core/src/exec/index.ts"],
      "@emdash/core/lib": ["../core/src/lib/index.ts"],
      "@emdash/core/mcp": ["../core/src/mcp/index.ts"],
      "@emdash/core/pty/node": ["../core/src/pty/node/index.ts"],
      "@emdash/core/pty": ["../core/src/pty/index.ts"],
      "@emdash/core/skills": ["../core/src/skills/index.ts"],
      "@emdash/shared/logger/node": ["../shared/src/logger/node/index.ts"],
      "@emdash/shared/logger": ["../shared/src/logger/index.ts"],
      "@emdash/shared/plugins": ["../shared/src/plugins/index.ts"],
      "@emdash/shared": ["../shared/src/index.ts"],
      "@emdash/wire/testing": ["../wire/src/testing/index.ts"],
      "@emdash/wire/util": ["../wire/src/util/index.ts"],
      "@emdash/wire": ["../wire/src/index.ts"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
