{
  "name": "@emdash/plugins",
  "version": "1.0.0",
  "description": "Plugin interfaces and helpers for agent providers",
  "keywords": [],
  "license": "Apache-2.0",
  "author": "",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    "./agents": {
      "types": "./dist/agents.d.mts",
      "default": "./dist/agents.mjs"
    },
    "./agents/types": {
      "types": "./dist/agents/types.d.mts",
      "default": "./dist/agents/types.mjs"
    },
    "./integrations": {
      "types": "./dist/integrations.d.mts",
      "default": "./dist/integrations.mjs"
    },
    "./issues": {
      "types": "./dist/issues.d.mts",
      "default": "./dist/issues.mjs"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "lint": "sh -c 'root=$(cd ../.. && pwd); cd \"$root/apps/emdash-desktop\" && pnpm exec oxlint --config .oxlintrc.json \"$root/packages/plugins/src\"'",
    "typecheck": "tsgo --noEmit",
    "generate:acp-fixture": "tsx tooling/fixtures/create-acp-transcript.ts"
  },
  "dependencies": {
    "@agentclientprotocol/claude-agent-acp": "^0.54.1",
    "@agentclientprotocol/codex-acp": "^1.0.2",
    "@agentclientprotocol/sdk": "^1.1.0",
    "@emdash/core": "workspace:*",
    "@emdash/shared": "workspace:*",
    "@gitbeaker/rest": "^43.8.0",
    "@linear/sdk": "^77.0.0",
    "@llamaduck/forgejo-ts": "^14.0.3",
    "@makeplane/plane-node-sdk": "^0.2.11",
    "@mondaydotcomorg/api": "^14.0.0",
    "@notionhq/client": "^5.22.0",
    "@octokit/rest": "^22.0.1",
    "@team-plain/graphql": "^1.0.1",
    "asana": "^3.1.12",
    "featurebase-node": "^0.14.0",
    "jira.js": "^5.4.0",
    "smol-toml": "^1.6.0",
    "trello.js": "^2.1.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@emdash/runtime": "workspace:*",
    "@emdash/wire": "workspace:*",
    "@typescript/native-preview": "7.0.0-dev.20260609.1",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.69.0",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.4",
    "vitest": "^3.1.4"
  },
  "packageManager": "pnpm@10.28.2"
}
