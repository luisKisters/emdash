{
  "name": "@emdash/core",
  "version": "1.0.0",
  "description": "Transport-agnostic core runtime primitives for Emdash",
  "license": "Apache-2.0",
  "author": {
    "name": "Emdash Contributors",
    "email": "support@emdash.sh"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./deps": {
      "types": "./dist/deps.d.mts",
      "default": "./dist/deps.mjs"
    },
    "./deps/runtime": {
      "types": "./dist/deps-runtime.d.mts",
      "default": "./dist/deps-runtime.mjs"
    },
    "./exec": {
      "types": "./dist/exec.d.mts",
      "default": "./dist/exec.mjs"
    },
    "./file-tree": {
      "types": "./dist/file-tree.d.mts",
      "default": "./dist/file-tree.mjs"
    },
    "./fs": {
      "types": "./dist/fs.d.mts",
      "default": "./dist/fs.mjs"
    },
    "./git": {
      "types": "./dist/git.d.mts",
      "default": "./dist/git.mjs"
    },
    "./lib": {
      "types": "./dist/lib.d.mts",
      "default": "./dist/lib.mjs"
    },
    "./storage": {
      "types": "./dist/storage.d.mts",
      "default": "./dist/storage.mjs"
    },
    "./agents/plugins": {
      "types": "./dist/agents-plugins.d.mts",
      "default": "./dist/agents-plugins.mjs"
    },
    "./agents/plugins/helpers": {
      "types": "./dist/agents-plugins-helpers.d.mts",
      "default": "./dist/agents-plugins-helpers.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest run",
    "lint": "sh -c 'root=$(cd ../.. && pwd); cd \"$root/apps/emdash-desktop\" && pnpm exec oxlint --config .oxlintrc.json \"$root/packages/core\"'",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@emdash/shared": "workspace:*",
    "@parcel/watcher": "^2.5.6",
    "semver": "^7.8.4",
    "smol-toml": "^1.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.42",
    "@types/semver": "^7.7.1",
    "@typescript/native-preview": "7.0.0-dev.20260609.1",
    "tsdown": "^0.22.2",
    "vitest": "^4.1.0"
  }
}
